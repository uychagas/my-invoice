<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Invoice {{ invoice.number }}</title>
    <style>
        @font-face {
            font-family: 'InvoiceSans';
            src: url('{{ fontFile }}') format('truetype');
            font-weight: normal;
            font-style: normal;
        }

        body {
            font-family: InvoiceSans, DejaVu Sans, Arial, sans-serif;
            font-size: 12px;
            color: #222;
            margin: 28px;
        }
        h1 {
            margin: 0 0 10px;
            font-size: 28px;
            color: #2a5d77;
            font-weight: 500;
        }
        h2 {
            margin: 20px 0 8px;
            font-size: 18px;
            color: #2a5d77;
            font-weight: 500;
        }
        p {
            margin: 2px 0;
            line-height: 1.35;
        }
        .muted-line {
            border-top: 1px solid #d7d7d7;
            margin: 14px 0 12px;
        }
        .parties {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 10px;
        }
        .parties td {
            width: 50%;
            vertical-align: top;
            padding-right: 10px;
        }
        table.items {
            width: 100%;
            border-collapse: collapse;
            margin-top: 8px;
        }
        table.items th,
        table.items td {
            border: 1px solid #666;
            padding: 6px 8px;
            font-size: 11px;
        }
        table.items th { background: #f6f6f6; text-align: left; }
        .num { text-align: right; white-space: nowrap; }
        .total {
            margin-top: 16px;
        }
        .total .amount {
            font-size: 20px;
            font-weight: 700;
        }
        .terms {
            border-top: 1px solid #d7d7d7;
            margin-top: 18px;
            padding-top: 10px;
        }
    </style>
</head>
<body>
{% set periodStart = (invoice.referenceMonth ~ '-01')|date('F j, Y') %}
{% set periodEnd = (invoice.referenceMonth ~ '-01')|date_modify('+1 month -1 day')|date('F j, Y') %}

<h1>INVOICE</h1>
<p><strong>Invoice Number:</strong> {{ invoice.number }}</p>
<p><strong>Invoice Date:</strong> {{ invoice.issueDate|date('F j, Y') }}</p>
<p><strong>Service Period:</strong> {{ periodStart }} - {{ periodEnd }}</p>

<div class="muted-line"></div>

<table class="parties">
    <tr>
        <td>
            <h2>From</h2>
            <p><strong>{{ invoice.issuerCompany.name }}</strong></p>
            {% if invoice.issuerCompany.address %}
                <p>{{ invoice.issuerCompany.address|nl2br }}</p>
            {% endif %}
            {% if invoice.issuerCompany.taxId %}
                <p>Tax ID: {{ invoice.issuerCompany.taxId }}</p>
            {% endif %}
            {% if invoice.issuerCompany.email %}
                <p>Email: {{ invoice.issuerCompany.email }}</p>
            {% endif %}
        </td>
        <td>
            <h2>Bill To</h2>
            <p><strong>{{ invoice.recipientCompany.name }}</strong></p>
            <p>Attn: Finance / Accounts Payable</p>
            {% if invoice.recipientCompany.address %}
                <p>{{ invoice.recipientCompany.address|nl2br }}</p>
            {% endif %}
            {% if invoice.recipientCompany.taxId %}
                <p>Tax ID: {{ invoice.recipientCompany.taxId }}</p>
            {% endif %}
            {% if invoice.recipientCompany.email %}
                <p>Email: {{ invoice.recipientCompany.email }}</p>
            {% endif %}
        </td>
    </tr>
</table>

<h2>Services Rendered</h2>
<table class="items">
    <thead>
    <tr>
        <th>Description</th>
        <th class="num">Quantity</th>
        <th class="num">Daily Rate ({{ invoice.currency }})</th>
        <th class="num">Amount ({{ invoice.currency }})</th>
    </tr>
    </thead>
    <tbody>
    {% for item in invoice.items %}
        <tr>
            <td>{{ item.description }}</td>
            <td class="num">{{ item.billingType == 'daily_rate' ? item.quantity|replace({'.00': ''}) : item.quantity }}</td>
            <td class="num">{{ item.unitPrice|number_format(2, '.', ',') }}</td>
            <td class="num">{{ item.totalAmount|number_format(2, '.', ',') }}</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

<div class="total">
    <h2>Total Due</h2>
    <p class="amount">{{ invoice.currency }} {{ invoice.totalAmount|number_format(2, '.', ',') }}</p>
</div>

<div class="terms">
    <p><strong>Payment Terms</strong></p>
    <p>Payment due within <strong>10 days</strong> of invoice submission.</p>
    <p>Due date: {{ invoice.dueDate ? invoice.dueDate|date('F j, Y') : '-' }}</p>
</div>

{% if invoice.notes %}
    <div class="terms">
        <p><strong>Notes</strong></p>
        <p>{{ invoice.notes|nl2br }}</p>
    </div>
{% endif %}
</body>
</html>
