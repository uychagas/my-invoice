{% extends 'base.html.twig' %}

{% block title %}Empresas{% endblock %}

{% block body %}
    <div class="page-head">
        <h1>Empresas</h1>
        <a class="btn" href="{{ path('app_company_new') }}">Nova empresa</a>
    </div>

    <div class="card">
        <table>
            <thead>
            <tr>
                <th>Nome</th>
                <th>Tipo</th>
                <th>País</th>
                <th>E-mail</th>
                <th>Tax ID</th>
                <th>Ações</th>
            </tr>
            </thead>
            <tbody>
            {% for company in companies %}
                <tr>
                    <td>{{ company.name }}</td>
                    <td>{{ company.type == 'provider' ? 'Minha PJ' : 'Destinatária' }}</td>
                    <td>{{ company.countryCode }}</td>
                    <td>{{ company.email ?: '-' }}</td>
                    <td>{{ company.taxId ?: '-' }}</td>
                    <td><a href="{{ path('app_company_edit', {id: company.id}) }}">Editar</a></td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6">Nenhuma empresa cadastrada.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
